# ============================================================
# MyVault — Required Environment Variables for Render
# ============================================================
# Copy these to Render Dashboard → Your Service → Environment
# ============================================================

MAIN_PIN=your_4_digit_pin_here
VAULT_PIN=your_vault_4_digit_pin_here
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/myvault
PORT=5000
FRONTEND_URL=https://your-frontend-name.onrender.com
